  "components": {
    "schemas": {
      "PromotionAccount": {
        "title": "PromotionAccount",
        "required": [
          "startDate",
          "title",
          "type"
        ],
        "type": "object",
        "properties": {
          "budget": {
            "minimum": 0,
            "exclusiveMinimum": false,
            "type": "number",
            "description": "The promotion budget."
          },
          "description": {
            "maxLength": 20000,
            "minLength": 0,
            "type": "string",
            "description": "The complete description of the promotion. It describes the promotion itself, about how the promotion works.",
            "example": "Buy 10, get 12 - Buy 12, get 16” or discounts \"10% off for all beers\"."
          },
          "endDate": {
            "type": "string",
            "description": "Promotion deactivation date. Needs to be > than startDate. It should be in UTC timezone. https://en.wikipedia.org/wiki/ISO_8601",
            "example": "2050-03-31T23:59:59.999Z"
          },
          "image": {
            "type": "string",
            "description": "Image used as background of the promotion.",
            "example": "https://www.socioscerveceria.com.do/media/catalog/product//b/a/barcelo_dark_series_350_ml_-_unidad_1_botella_dar_siri_.png"
          },
          "promotionId": {
            "type": "string",
            "description": "Unique identifier for the promotion. Required.",
            "example": "Becks01"
          },
          "quantityLimit": {
            "minimum": 1,
            "exclusiveMinimum": false,
            "type": "integer",
            "description": "The promotion quantity limit.",
            "format": "int32",
            "example": 10
          },
          "startDate": {
            "type": "string",
            "description": "Promotion activation date. It should be in UTC timezone. https://en.wikipedia.org/wiki/ISO_8601",
            "example": "2020-01-01T00:00:00.000Z"
          },
          "title": {
            "maxLength": 255,
            "minLength": 1,
            "type": "string",
            "description": "The promotion title. The label displayed on the promotion list.",
            "example": "Buy 3 get 1 free"
          },
          "type": {
            "type": "string",
            "description": "The promotion type that can be one of the following: DISCOUNT, FREE_GOOD, STEPPED_DISCOUNT, STEPPED_FREE_GOOD and FLEXIBLE_DISCOUNT.",
            "example": "STEPPED_DISCOUNT",
            "enum": [
              "STEPPED_DISCOUNT",
              "STEPPED_FREE_GOOD",
              "DISCOUNT",
              "FREE_GOOD",
              "FLEXIBLE_DISCOUNT"
            ]
          }
        }
      },
      "PromotionDeleteRequest": {
        "title": "PromotionDeleteRequest",
        "type": "object",
        "x-examples": {
          "example-1": {
            "accounts": [
              "string"
            ],
            "promotions": [
              "string"
            ]
          }
        },
        "properties": {
          "accounts": {
            "type": "array",
            "description": "AccountId list.",
            "deprecated": true,
            "items": {
              "type": "string"
            }
          },
          "promotions": {
            "type": "array",
            "description": "PromotionId list.",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "promotions"
        ]
      }
    },
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic"
      }
    }
  }
