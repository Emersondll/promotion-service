{
  "openapi": "3.0.1",
  "info": {
    "title": "Promotion Service V2",
    "description": "\"REST API for AB-Inbev Promotion Service Microservice\"",
    "license": {
      "name": "Anheuser-Busch InBev © 2021"
    },
    "version": "2.0.1-SNAPSHOT"
  },
  "servers": [
    {
      "url": "https://services-dev.bees-platform.dev/api/promotion-service/v2/",
      "description": "dev"
    },
    {
      "url": "https://services-uat.bees-platform.dev/api/promotion-service/v2/",
      "description": "uat"
    },
    {
      "url": "https://services-sit.bees-platform.dev/api/promotion-service/v2/",
      "description": "sit"
    }
  ],
  "security": [
    {
      "Authorization": []
    }
  ],
  "tags": [
    {
      "name": "Promotion Service API",
      "description": "ABI B2B global promotion service."
    }
  ],
  "paths": {
    "/promotions": {
      "get": {
        "summary": "GET /promotions",
        "tags": [
          "Multi-Vendor"
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "promotions": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/PromotionMultivendorV2Response"
                      }
                    },
                    "pagination": {
                      "$ref": "#/components/schemas/Pagination"
                    }
                  }
                },
                "examples": {
                  "example-1": {
                    "value": {
                      "promotions": [
                        {
                          "promotionId": "3eaf888b-516c-4eac-ac00-1312640986a2",
                          "vendorPromotionId": "PROMOTION001",
                          "vendorId": "3c8023c1-8d12-4f64-b11d-5f3172abf3ab",
                          "title": "Buy 3 get 1 free",
                          "description": "Buy 10, get 12 - Buy 12, get 16 or discounts 10% off for all beers.",
                          "type": "STEPPED_DISCOUNT",
                          "startDate": "2020-01-20T18:00:00.000Z",
                          "endDate": "2020-01-20T18:00:00.000Z",
                          "image": "http://example.com",
                          "updatedAt": "2020-01-20T18:00:00.000Z"
                        }
                      ],
                      "pagination": {
                        "page": 4,
                        "size": 20,
                        "totalElements": 100,
                        "totalPages": 5
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden"
          },
          "500": {
            "description": "Internal Server Error"
          }
        },
        "operationId": "get-Promotions",
        "description": "This endpoint retrieves a list of valid promotions bringing only promotion metadata without account association and list of vendorItemIds, to have account association and the vendorItemIds it's necessary to call deals MS.",
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "in": "header",
            "name": "country",
            "description": "Country/region. ISO 3166 alpha-2 country code.",
            "required": true
          },
          {
            "schema": {
              "type": "string"
            },
            "in": "header",
            "name": "requestTraceId",
            "description": "Cross transaction unique ID. Used to track the request across systems.",
            "required": true
          },
          {
            "schema": {
              "type": "string",
              "example": "vendorId=3c8023c1-8d12-4f64-b11d-5f3172abf3ab"
            },
            "in": "query",
            "name": "vendorId",
            "description": "Vendor Id to have the promotions returned."
          },
          {
            "schema": {
              "type": "array",
              "example": "vendorPromotionIds=VNPROMO123,VNPROMO456"
            },
            "in": "query",
            "name": "vendorPromotionIds",
            "description": "Vendor Promotion Ids to have the promotions returned."
          },
          {
            "schema": {
              "type": "integer",
              "format": "int32",
              "minimum": 0,
              "default": 0
            },
            "in": "query",
            "name": "page",
            "description": "Number of the current page being returned. The first page is number zero."
          },
          {
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 100
            },
            "in": "query",
            "name": "pageSize",
            "description": "Number of elements being returned per page."
          },
          {
            "schema": {
              "type": "array",
              "enum": [
                "STEPPED_DISCOUNT",
                "STEPPED_FREE_GOOD",
                "DISCOUNT",
                "FREE_GOOD",
                "FLEXIBLE_DISCOUNT"
              ],
              "example": "types=STEPPED_DISCOUNT, FLEXIBLE_DISCOUNT"
            },
            "in": "query",
            "name": "types",
            "description": "The types to have the promotions returned."
          },
          {
            "schema": {
              "type": "string"
            },
            "in": "header",
            "name": "accept-language",
            "description": "Information about the response language preferences (eg. en-US represents English as spoken in the United States). More details about the locale on https://www.oracle.com/java/technologies/javase/jdk11-suported-locales.html"
          },
          {
            "schema": {
              "type": "array",
              "example": "promotionIds=09f9e275-8a0a-3496-8586-3e81d0402b7a"
            },
            "in": "query",
            "name": "promotionIds",
            "description": "The promotion unique id to have the promotions returned."
          },
          {
            "schema": {
              "type": "string",
              "example": "BRAHMA"
            },
            "in": "query",
            "name": "query",
            "description": "Used to filter by word on title and description of promotions."
          },
          {
            "schema": {
              "type": "boolean",
              "default": "false"
            },
            "in": "query",
            "name": "ignoreStartDate",
            "description": "Used to ignore the startDate filter of promotions."
          }
        ]
      },
      "parameters": []
    }
  },
  "components": {
    "schemas": {
      "Pagination": {
        "title": "Pagination",
        "type": "object",
        "x-examples": {
          "example-1": {
            "page": 4,
            "size": 20,
            "totalElements": 100,
            "totalPages": 5
          }
        },
        "properties": {
          "page": {
            "type": "integer",
            "description": "Current page number. The first page is zero.",
            "format": "int32",
            "example": 4
          },
          "size": {
            "type": "integer",
            "description": "Size of each page.",
            "format": "int32",
            "example": 20
          },
          "totalElements": {
            "type": "integer",
            "format": "int32",
            "example": 100,
            "description": "Total number of promotions."
          },
          "totalPages": {
            "type": "integer",
            "description": "Total number of pages.",
            "format": "int32",
            "example": 5
          }
        }
      },
      "PromotionMultivendorV2Response": {
        "title": "PromotionMultivendorV2Response",
        "type": "object",
        "x-examples": {
          "example-1": {
            "promotionId": "3eaf888b-516c-4eac-ac00-1312640986a2",
            "vendorPromotionId": "PROMOTION001",
            "vendorId": "3c8023c1-8d12-4f64-b11d-5f3172abf3ab",
            "title": "Buy 3 get 1 free",
            "description": "Buy 10, get 12 - Buy 12, get 16 or discounts 10% off for all beers.",
            "type": "STEPPED_DISCOUNT",
            "startDate": "2020-01-20T18:00:00.000Z",
            "endDate": "2020-01-20T18:00:00.000Z",
            "image": "http://example.com",
            "updatedAt": "2020-01-20T18:00:00.000Z"
          }
        },
        "description": "",
        "properties": {
          "promotionId": {
            "type": "string",
            "format": "uuid",
            "description": "Promotion internal id."
          },
          "vendorPromotionId": {
            "type": "string",
            "description": "Promotion ID from external Source.",
            "example": "PROMOTION001"
          },
          "vendorId": {
            "type": "string",
            "example": "3c8023c1-8d12-4f64-b11d-5f3172abf3ab"
          },
          "title": {
            "type": "string",
            "description": "The promotion title. The label displayed on the promotion list.",
            "example": "Buy 3 get 1 free"
          },
          "description": {
            "type": "string",
            "description": "The complete description of the promotion. It describes the promotion itself, about how the promotion works.",
            "example": "Buy 10, get 12 - Buy 12, get 16 or discounts 10% off for all beers."
          },
          "type": {
            "type": "string",
            "description": "The type of the promotion.",
            "example": "STEPPED_DISCOUNT",
            "enum": [
              "STEPPED_DISCOUNT",
              "STEPPED_FREE_GOOD",
              "DISCOUNT",
              "FREE_GOOD",
              "FLEXIBLE_DISCOUNT"
            ]
          },
          "startDate": {
            "type": "string",
            "description": "Promotion activation date.",
            "example": "2020-01-20T18:00:00.000Z",
            "format": "date-time"
          },
          "endDate": {
            "type": "string",
            "description": "Promotion deactivation date.",
            "example": "2020-01-20T18:00:00.000Z",
            "format": "date-time"
          },
          "image": {
            "type": "string",
            "description": "Image used as background of the promotion.",
            "format": "uri"
          },
          "updatedAt": {
            "type": "string",
            "description": "Date that the promotion was updated.",
            "example": "2020-01-20T18:00:00.000Z",
            "format": "date-time"
          }
        },
        "required": [
          "promotionId",
          "vendorPromotionId",
          "title",
          "type",
          "startDate",
          "endDate"
        ]
      }
    },
    "securitySchemes": {
      "Authorization": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  }
}