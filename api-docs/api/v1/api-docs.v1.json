    "/promotions": {
      "get": {
        "summary": "GET /promotions",
        "tags": [
          "Multi-Vendor"
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "promotions": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/PromotionMultivendorResponse"
                      }
                    },
                    "pagination": {
                      "$ref": "#/components/schemas/Pagination"
                    }
                  }
                },
                "examples": {
                  "example-1": {
                    "value": {
                      "promotions": [
                        {
                          "vendorPromotionId": "PROMOTION001",
                          "title": "Buy 3 get 1 free",
                          "description": "Buy 10, get 12 - Buy 12, get 16 or discounts 10% off for all beers.",
                          "type": "STEPPED_DISCOUNT",
                          "budget": 100.5,
                          "startDate": "2020-01-20T18:00:00.000Z",
                          "endDate": "2020-01-20T18:00:00.000Z",
                          "image": "http://example.com",
                          "quantityLimit": 10,
                          "vendorItemIds": [
                            "12345",
                            "54321"
                          ],
                          "updatedAt": "2020-01-20T18:00:00.000Z",
                          "id": "497f6eca-6276-4993-bfeb-53cbbbba6f08"
                        }
                      ],
                      "pagination": {
                        "page": 4,
                        "size": 20,
                        "totalPages": 5
                      }
                    }
                  }
                }
              }
            }
          },
          "403": {
            "description": "Forbidden"
          },
          "404": {
            "description": "Not Found"
          }
        },
        "operationId": "get-Promotions",
        "description": "Retrieve a list of valid promotions.",
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "in": "header",
            "name": "country",
            "description": "Country/region. ISO 3166 alpha-2 country code.",
            "required": true
          },
          {
            "schema": {
              "type": "string"
            },
            "in": "header",
            "name": "requestTraceId",
            "description": "Cross transaction unique ID. Used to track the request across systems.",
            "required": true
          },
          {
            "schema": {
              "type": "string"
            },
            "in": "query",
            "name": "vendorId",
            "description": "Vendor Id to have the promotions returned.",
            "required": true
          },
          {
            "schema": {
              "type": "string"
            },
            "in": "query",
            "name": "vendorAccountId",
            "description": "Vendor Account Id to have the promotions returned.",
            "required": true
          },
          {
            "schema": {
              "type": "array",
              "example": "vendorPromotionIds=VNPROMO123,VNPROMO456"
            },
            "in": "query",
            "name": "vendorPromotionIds",
            "description": "Vendor Promotion Ids to have the promotions returned."
          },
          {
            "schema": {
              "type": "array",
              "example": "vendorItemIds=ITEM123,ITEM456"
            },
            "in": "query",
            "name": "vendorItemIds",
            "description": "Vendor Item Ids to have the promotions returned."
          },
          {
            "schema": {
              "type": "integer",
              "format": "int32",
              "minimum": 0,
              "default": 0
            },
            "in": "query",
            "name": "page",
            "description": "Number of the current page being returned. The first page is number zero."
          },
          {
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 1000
            },
            "in": "query",
            "name": "pageSize",
            "description": "Number of elements being returned per page."
          },
          {
            "schema": {
              "type": "array",
              "enum": [
                "STEPPED_DISCOUNT",
                "STEPPED_FREE_GOOD",
                "DISCOUNT",
                "FREE_GOOD",
                "FLEXIBLE_DISCOUNT"
              ],
              "example": "types=STEPPED_DISCOUNT, FLEXIBLE_DISCOUNT"
            },
            "in": "query",
            "name": "types",
            "description": "The types to have the promotions returned."
          },
          {
            "schema": {
              "type": "string"
            },
            "in": "header",
            "name": "accept-language",
            "description": "Information about the response language preferences (eg. en-US represents English as spoken in the United States). More details about the locale on https://www.oracle.com/java/technologies/javase/jdk11-suported-locales.html"
          }
        ]
      },
      "parameters": []
    }
  },
  "components": {
    "schemas": {
      "AccountPromotionVO": {
        "title": "AccountPromotionVO",
        "type": "object",
        "properties": {
          "accountId": {
            "type": "string",
            "description": "Account ID from external Source.",
            "example": "00001000004"
          },
          "budget": {
            "type": "number",
            "description": "Promotion budget.",
            "example": 100.5
          },
          "description": {
            "type": "string",
            "description": "The complete description of the promotion. It describes the promotion itself, about how the promotion works.",
            "example": "Buy 10, get 12 - Buy 12, get 16” or discounts \"10% off for all beers\"."
          },
          "endDate": {
            "type": "string",
            "description": "Promotion deactivation date.",
            "example": "2020-01-20T18:00:00.000Z"
          },
          "id": {
            "type": "string",
            "description": "Unique identifier for the promotion.",
            "example": "1"
          },
          "image": {
            "type": "string",
            "description": "Image used as background of the promotion.",
            "example": "https://www.socioscerveceria.com.do/media/catalog/product//b/a/barcelo_dark_series_350_ml_-_unidad_1_botella_dar_siri_.png"
          },
          "internalId": {
            "type": "string",
            "description": "Internal ID from external Source.",
            "example": "1"
          },
          "promotionId": {
            "type": "string",
            "description": "Promotion ID from external Source.",
            "example": "PROMOTION001"
          },
          "promotionsRanking": {
            "type": "integer",
            "description": "Promotion ranking of the product.",
            "format": "int32",
            "example": 100
          },
          "quantityLimit": {
            "type": "integer",
            "description": "Integer of the consumption limit of the promotion.",
            "format": "int32",
            "example": 10
          },
          "score": {
            "type": "number",
            "description": "Promotion Score.",
            "example": 100
          },
          "skus": {
            "type": "array",
            "description": "The list of sku ID that are part of the promotion.",
            "example": [
              "12345",
              "54321"
            ],
            "items": {
              "type": "string"
            }
          },
          "title": {
            "type": "string",
            "description": "The promotion title. The label displayed on the promotion list.",
            "example": "Buy 3 get 1 free"
          },
          "type": {
            "type": "string",
            "description": "The type of the promotion.",
            "example": "FLEXIBLE_DISCOUNT",
            "enum": [
              "STEPPED_DISCOUNT",
              "STEPPED_FREE_GOOD",
              "DISCOUNT",
              "FREE_GOOD",
              "FLEXIBLE_DISCOUNT"
            ]
          },
          "updatedAt": {
            "type": "string",
            "description": "Date that the promotion was updated.",
            "example": "2020-01-20T18:00:00.000Z"
          }
        }
      },
      "GetAllPromotionsResult": {
        "title": "GetAllPromotionsResult",
        "type": "object",
        "properties": {
          "pagination": {
            "$ref": "#/components/schemas/Pagination"
          },
          "promotions": {
            "type": "array",
