        "title": "PromotionResponseListByAccount",
        "type": "object",
        "properties": {
          "accountId": {
            "type": "string"
          },
          "promotions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PromotionResponse"
            }
          }
        }
      },
      "PromotionScore": {
        "title": "PromotionScore",
        "required": [
          "promotionId",
          "score"
        ],
        "type": "object",
        "properties": {
          "promotionId": {
            "type": "string",
            "description": "Promotion ID."
          },
          "score": {
            "type": "number",
            "description": "The promotion score. Integer value that represents a rank value for sorting."
          }
        }
      },
      "PromotionSkuGroup": {
        "title": "PromotionSkuGroup",
        "required": [
          "skuGroupId",
          "skus"
        ],
        "type": "object",
        "properties": {
          "skuGroupId": {
            "type": "string",
            "description": "The sku group ID. This ID will be used to link the sku provided to a promotion with this sku group."
          },
          "skus": {
            "type": "array",
            "example": [
              "SKU001",
              "SKU002",
              "SKU003"
            ],
            "items": {
              "type": "string"
            }
          }
        }
      },
      "PromotionVO": {
        "title": "PromotionVO",
        "required": [
          "accountGroupIds",
          "description",
          "id",
          "skuGroupIds",
          "title",
          "type"
        ],
        "type": "object",
        "properties": {
          "accountGroupIds": {
            "type": "array",
            "description": "The account groups of this promotion. This will link an account group to this promotion. With this information the middleware can identify for which accounts this promotion is available.",
            "example": [
              "12345",
              "54321"
            ],
            "items": {
              "type": "string"
            }
          },
          "budget": {
            "type": "number",
            "description": "Budget of the promotion.",
            "example": 100.5
          },
          "description": {
            "type": "string",
            "description": "The complete description of the promotion. It describes the promotion itself, about how the promotion works.",
            "example": "Buy 10, get 12 - Buy 12, get 16” or discounts \"10% off for all beers\"."
          },
          "disabled": {
            "type": "boolean",
            "description": "Tells if a promotion is disabled or not for an account.",
            "example": false
          },
          "endDate": {
            "type": "string",
            "description": "Promotion deactivation date. Needs to be > than startDate. It should be in UTC timezone. https://en.wikipedia.org/wiki/ISO_8601",
            "example": "2019-03-31T23:59:59.999Z"
          },
          "freeGoodGroupIds": {
            "type": "array",
            "description": "The free good groups of this promotion. This will link this promotion to the sku’s that will be free goodies when affected by this promotion. This field is required when promotion type is FREE_GOOD or STEPPED_FREE_GOOD.",
            "example": [
              "12345",
              "54321"
            ],
            "items": {
              "type": "string"
            }
          },
          "hidden": {
            "type": "boolean",
            "description": "Tells if a promotion is hidden or not for an account. Hidden promotions won't be shown by the GET operations.",
            "example": false
          },
          "id": {
            "type": "string",
            "description": "Unique identifier for the promotion.",
            "example": "1"
          },
          "promotionId": {
            "type": "string",
            "description": "Promotion ID from external source.",
            "example": "PROMOTION001"
          },
          "promotionsRanking": {
            "type": "integer",
            "description": "The ranking of this promotion. This will link a ranking to this promotion. with this information the middleware can identity the ranking position of this promotion.",
            "format": "int32",
            "example": 100
          },
          "quantityLimit": {
            "type": "integer",
            "description": "Integer of the consumption limit of the promotion.",
            "format": "int32",
            "example": 10
          },
          "skuGroupIds": {
            "type": "array",
            "description": "The sku groups of this promotion. This will link this promotion to the sku's affected by this promotion. with this information the middleware can identity with sku's this promotion have.",
            "example": [
              "12345",
              "54321"
            ],
            "items": {
              "type": "string"
            }
          },
          "startDate": {
            "type": "string",
            "description": "Promotion activation date. It should be in UTC timezone. https://en.wikipedia.org/wiki/ISO_8601",
            "example": "2019-03-04T00:00:00.000Z"
          },
          "title": {
            "type": "string",
            "description": "The promotion title. The label displayed on the promotion list.",
            "example": "Buy 3 get 1 free"
          },
          "type": {
            "type": "string",
            "description": "The promotion type that can be one of the following: DISCOUNT, FREE_GOOD, STEPPED_DISCOUNT and STEPPED_FREE_GOOD.",
            "example": "STEPPED_DISCOUNT",
            "enum": [
              "STEPPED_DISCOUNT",
              "STEPPED_FREE_GOOD",
              "DISCOUNT",
              "FREE_GOOD",
              "FLEXIBLE_DISCOUNT"
            ]
          }
        }
      },
