  "paths": {
    "/": {
      "get": {
        "tags": [
          "Single-Vendor"
        ],
        "summary": "Promotion Information",
        "description": "Retrieves the promotion detailed information",
        "operationId": "getPromotionsUsingGET",
        "parameters": [
          {
            "name": "accountId",
            "in": "query",
            "description": "Point of consumption unique identifier",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "updatedSince",
            "in": "query",
            "description": "A filter to retrieve just promotions that were updated after provided date",
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 0
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "description": "Page size",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 50
            }
          },
          {
            "name": "includeDisabled",
            "in": "query",
            "description": "Include disabled promotions",
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "requestTraceId",
            "in": "header",
            "description": "Cross transaction unique ID. Used to track the request across systems",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "country",
            "in": "header",
            "description": "Country/region. ISO 3166 alpha-2 country code",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "schema": {
              "type": "array",
              "enum": [
                "STEPPED_DISCOUNT",
                "STEPPED_FREE_GOOD",
                "DISCOUNT",
                "FREE_GOOD",
                "FLEXIBLE_DISCOUNT"
              ]
            },
            "in": "query",
            "name": "types",
            "description": "A filter to retrieve just promotions with specific types"
          },
          {
            "schema": {
              "type": "string"
            },
            "in": "query",
            "name": "sku",
            "description": "A filter to retrieve just promotions with specific sku"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetAllPromotionsResult"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {}
          },
          "401": {
            "description": "Unauthorized",
            "content": {}
          },
          "403": {
            "description": "Forbidden",
            "content": {}
          },
          "404": {
            "description": "Not Found",
            "content": {}
          }
        }
      }
    },
    "/accounts": {
      "get": {
        "tags": [
          "Single-Vendor"
        ],
        "summary": "Promotion Information grouped by account",
        "description": "Retrieves the promotion detailed information grouped by account",
        "operationId": "getPromotionsByAccountUsingGET",
        "parameters": [
          {
            "name": "accounts",
            "in": "query",
            "description": "List of accounts",
            "style": "form",
            "explode": true,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "updatedSince",
            "in": "query",
            "description": "A filter to retrieve just promotions that were updated after provided date",
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 0
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "description": "Page size",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 50
            }
          },
          {
            "name": "includeDisabled",
            "in": "query",
            "description": "Include disabled promotions",
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "requestTraceId",
            "in": "header",
            "description": "Cross transaction unique ID. Used to track the request across systems",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "country",
            "in": "header",
            "description": "Country/region. ISO 3166 alpha-2 country code",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetPromotionsGroupedByAccountVO"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {}
          },
          "401": {
            "description": "Unauthorized",
            "content": {}
          },
          "403": {
            "description": "Forbidden",
            "content": {}
          },
          "404": {
            "description": "Not Found",
            "content": {}
          }
        },
        "deprecated": true
      }
    },
    "/{accountId}/{promotionId}": {
