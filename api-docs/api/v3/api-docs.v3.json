{
  "openapi": "3.0.1",
  "info": {
    "title": "Promotion Service V3",
    "description": "\"REST API for AB-Inbev Promotion Service Microservice\"",
    "license": {
      "name": "Anheuser-Busch InBev © 2021"
    },
    "version": "2.0.1-SNAPSHOT"
  },
  "servers": [
    {
      "url": "https://services-dev.bees-platform.dev/api/promotion-service/v3/",
      "description": "dev"
    },
    {
      "url": "https://services-uat.bees-platform.dev/api/promotion-service/v3/",
      "description": "uat"
    },
    {
      "url": "https://services-sit.bees-platform.dev/api/promotion-service/v3/",
      "description": "sit"
    }
  ],
  "security": [
    {
      "Authorization": []
    }
  ],
  "tags": [
    {
      "name": "Promotion Service API",
      "description": "ABI B2B global promotion service."
    }
  ],
  "paths": {
    "/promotions": {
      "get": {
        "summary": "GET /promotions",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "promotions": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/PromotionMarketplaceResponse"
                      }
                    },
                    "pagination": {
                      "$ref": "#/components/schemas/PaginationMarketplace"
                    }
                  }
                },
                "examples": {
                  "example-1": {
                    "value": {
                      "promotions": [
                        {
                          "platformUniqueIds": {
                            "promotionId": "string",
                            "promotionPlatformId": "string"
                          },
                          "vendorUniqueIds": {
                            "vendorId": "string",
                            "vendorPromotionId": "string"
                          },
                          "title": "Buy 3 get 1 free",
                          "description": "Buy 10, get 12 - Buy 12, get 16 or discounts 10% off for all beers.",
                          "type": "STEPPED_DISCOUNT",
                          "startDate": "2020-01-20T18:00:00.000Z",
                          "endDate": "2020-01-20T18:00:00.000Z",
                          "image": "http://example.com"
                        }
                      ],
                      "pagination": {
                        "page": 4,
                        "hasNext": false
                      }
                    }
                  }
                }
              }
            }
          },
          "201": {
            "description": "Created"
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden"
          },
          "500": {
            "description": "Internal Server Error"
          }
        },
        "operationId": "get-Promotions",
        "description": "This endpoint retrieves a list of valid promotions bringing only promotion metadata without account association and list of vendorItemIds, to have account association and the vendorItemIds it's necessary to call deals MS. It is obrigatory to send a list of vendorIds OR a list of promotionPlatformIds.",
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "in": "header",
            "name": "country",
            "description": "Country/region. ISO 3166 alpha-2 country code.",
            "required": true
          },
          {
            "schema": {
              "type": "string"
            },
            "in": "header",
            "name": "requestTraceId",
            "description": "Cross transaction unique ID. Used to track the request across systems.",
            "required": true
          },
          {
            "$ref": "#/components/parameters/promotionPlatformIds"
          },
          {
            "schema": {
              "type": "array",
              "example": "vendorIds=VENDOR1,VENDOR2"
            },
            "in": "query",
            "name": "vendorIds",
            "description": "VendorIds to have the promotions returned."
          },
          {
            "schema": {
              "type": "integer",
              "format": "int32",
              "minimum": 0,
              "default": 0
            },
            "in": "query",
            "name": "page",
            "description": "Number of the current page being returned. The first page is number zero."
          },
          {
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 50
            },
            "in": "query",
            "name": "pageSize",
            "description": "Number of elements being returned per page. Max size is 50."
          },
          {
            "schema": {
              "type": "array",
              "enum": [
                "STEPPED_DISCOUNT",
                "STEPPED_FREE_GOOD",
                "DISCOUNT",
                "FREE_GOOD",
                "FLEXIBLE_DISCOUNT"
              ],
              "example": "types=STEPPED_DISCOUNT, FLEXIBLE_DISCOUNT"
            },
            "in": "query",
            "name": "types",
            "description": "The types to have the promotions returned."
          },
          {
            "schema": {
              "type": "string"
            },
            "in": "header",
            "name": "accept-language",
            "description": "Information about the response language preferences (eg. en-US represents English as spoken in the United States). More details about the locale on https://www.oracle.com/java/technologies/javase/jdk11-suported-locales.html"
          },
          {
            "schema": {
              "type": "string",
              "example": "BRAHMA"
            },
            "in": "query",
            "name": "query",
            "description": "Used to filter by word on title and description of promotions."
          },
          {
            "schema": {
              "type": "boolean",
              "default": "false"
            },
            "in": "query",
            "name": "ignoreStartDate",
            "description": "Used to ignore the startDate filter of promotions."
          }
        ],
        "tags": [
          "Marketplace"
        ]
      },
      "parameters": []
    }
  },
  "components": {
    "schemas": {
      "PaginationMarketplace": {
        "title": "Pagination",
        "type": "object",
        "x-examples": {
          "example-1": {
            "page": 4,
            "hasNext": false
          }
        },
        "properties": {
          "page": {
            "type": "integer",
            "description": "Current page number. The first page is zero.",
            "format": "int32",
            "example": 4
          },
          "hasNext": {
            "type": "boolean",
            "default": false
          }
        }
      },
      "PromotionMarketplaceResponse": {
        "title": "PromotionMarketplaceResponse",
        "type": "object",
        "x-examples": {
          "example-1": {
            "platformUniqueIds": {
              "promotionId": "string",
              "promotionPlatformId": "string"
            },
            "vendorUniqueIds": {
              "vendorId": "string",
              "vendorPromotionId": "string"
            },
            "title": "Buy 3 get 1 free",
            "description": "Buy 10, get 12 - Buy 12, get 16 or discounts 10% off for all beers.",
            "type": "STEPPED_DISCOUNT",
            "startDate": "2020-01-20T18:00:00.000Z",
            "endDate": "2020-01-20T18:00:00.000Z",
            "image": "http://example.com"
          }
        },
        "description": "",
        "properties": {
          "platformUniqueIds": {
            "type": [
              "object",
              "string"
            ],
            "format": "uuid",
            "description": "platformUniqueIds from source.",
            "properties": {
              "promotionId": {
                "type": "string"
              },
              "promotionPlatformId": {
                "type": "string"
              }
            }
          },
          "vendorUniqueIds": {
            "type": "object",
            "description": "vendorUniqueIds from source.\n",
            "properties": {
              "vendorId": {
                "type": "string"
              },
              "vendorPromotionId": {
                "type": "string"
              }
            }
          },
          "title": {
            "type": "string",
            "description": "The promotion title. The label displayed on the promotion list.",
            "example": "Buy 3 get 1 free"
          },
          "description": {
            "type": "string",
            "description": "The complete description of the promotion. It describes the promotion itself, about how the promotion works.",
            "example": "Buy 10, get 12 - Buy 12, get 16 or discounts 10% off for all beers."
          },
          "type": {
            "type": "string",
            "description": "The type of the promotion.",
            "example": "STEPPED_DISCOUNT",
            "enum": [
              "STEPPED_DISCOUNT",
              "STEPPED_FREE_GOOD",
              "DISCOUNT",
              "FREE_GOOD",
              "FLEXIBLE_DISCOUNT"
            ]
          },
          "startDate": {
            "type": "string",
            "description": "Promotion activation date.",
            "example": "2020-01-20T18:00:00.000Z",
            "format": "date-time"
          },
          "endDate": {
            "type": "string",
            "description": "Promotion deactivation date.",
            "example": "2020-01-20T18:00:00.000Z",
            "format": "date-time"
          },
          "image": {
            "type": "string",
            "description": "Image used as background of the promotion.",
            "format": "uri"
          }
        },
        "required": [
          "platformUniqueIds",
          "vendorUniqueIds",
          "title",
          "type",
          "startDate",
          "endDate"
        ]
      }
    },
    "securitySchemes": {
      "Authorization": {
        "type": "http",
        "scheme": "bearer"
      }
    },
    "parameters": {
      "promotionPlatformIds": {
        "name": "promotionPlatformIds",
        "in": "query",
        "required": false,
        "schema": {
          "type": "array",
          "maxItems": 50,
          "minItems": 0,
          "example": "promotionPlatformIds=VXJMaHhWZUtSRjZGeGRHUXk2amZMUT09OzM3OA==,VXJMaHhWZUtSRjZGeGRHUXk2amZMUT09OzMwMg%3D%3D"
        },
        "description": "List of deterministic promotionIds, it is a encripted field composed by vendorId and vendorPromotionId."
      }
    }
  }
}